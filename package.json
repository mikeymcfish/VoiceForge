{
  "name": "voiceforge-studio",
  "version": "2.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit --incremental false",
    "test:prompts": "tsx scripts/prompt-smoke-test.ts",
    "test:prompts:run": "cross-env RUN_TESTS=1 tsx scripts/prompt-smoke-test.ts",
    "test:text": "tsx scripts/text-processing-selftest.ts",
    "test:speech": "tsx scripts/speech-integration-selftest.ts",
    "test:audio-postprocess": "tsx scripts/audio-postprocess-selftest.ts",
    "test:hf-contract": "tsx scripts/hf-space-contract-selftest.ts",
    "test:voices": "tsx scripts/voice-library-selftest.ts",
    "test:mcp": "tsx scripts/mcp-selftest.ts",
    "test:mcp-auth": "tsx scripts/mcp-auth-selftest.ts",
    "test:loopback-policy": "tsx scripts/loopback-request-policy-selftest.ts",
    "build:plugin": "esbuild scripts/voiceforge-mcp-bridge.ts --bundle --platform=node --format=esm --target=node22 --outfile=codex-plugin/voiceforge/scripts/voiceforge-mcp-bridge.mjs",
    "test:plugin": "tsx scripts/voiceforge-global-plugin-selftest.ts",
    "test:plugin:autostart": "tsx scripts/voiceforge-plugin-autostart-selftest.ts"
  },
  "dependencies": {
    "@gradio/client": "^2.3.1",
    "@huggingface/inference": "^4.11.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tanstack/react-query": "^5.60.5",
    "@types/adm-zip": "^0.5.7",
    "@types/multer": "^2.0.0",
    "adm-zip": "^0.5.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.453.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "node-html-parser": "^7.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "wouter": "^3.3.5",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  }
}
